# ─── Server (Express API runs internally on :5000) ───────────
NODE_ENV=development

# Database (MySQL/MariaDB)
DATABASE_URL="mysql://user:password@localhost:3306/ph_erp_db"

# JWT — generate strong random secrets for production
JWT_SECRET=change-me
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=change-me-too
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Frontend URL (dev only; in the unified build the UI is same-origin)
FRONTEND_URL=http://localhost:3000

# ─── Email (optional — enables password-reset, invoice & reminder emails) ──
# Leave SMTP_HOST blank to disable email; the app degrades gracefully.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Finara ERP <no-reply@yourcompany.com>"
APP_URL=http://localhost:3000

# ─── Database backups (npm run db:backup) ────────────────────
# Full path to mysqldump if not on PATH; number of dumps to keep.
MYSQLDUMP_PATH="C:/Program Files/MySQL/MySQL Server 9.4/bin/mysqldump.exe"
BACKUP_RETENTION=14

# Company defaults
DEFAULT_COMPANY_NAME="Your Company Name"
DEFAULT_COMPANY_TIN="000-000-000-000"
DEFAULT_COMPANY_ADDRESS="Manila, Philippines"

# ─── Frontend (Next.js) ──────────────────────────────────────
# Server-side proxy target for /api/* (see next.config.js rewrites).
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_APP_NAME="PH-ERP Accounting"
NEXT_PUBLIC_COMPANY_NAME="Your Company Name"
