// ─── Remittances ───────────────────────────────────────────
enum RemittanceType {
  SSS
  PHILHEALTH
  PAGIBIG
  BIR_1601C
}

enum RemittanceStatus {
  DRAFT
  FILED
  PAID
  OVERDUE
}

model RemittancePeriod {
  id                 Int                @id @default(autoincrement())
  type               RemittanceType
  periodMonth        Int
  periodYear         Int
  dueDate            DateTime           @db.Date
  totalEmployeeShare Decimal            @default(0) @db.Decimal(15, 2)
  totalEmployerShare Decimal            @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal            @default(0) @db.Decimal(15, 2)
  status             RemittanceStatus   @default(DRAFT)
  referenceNo        String?            @db.VarChar(100)
  filedDate          DateTime?          @db.Date
  paidDate           DateTime?          @db.Date
  paidAmount         Decimal?           @db.Decimal(15, 2)
  penalty            Decimal            @default(0) @db.Decimal(15, 2)
  isManual           Boolean            @default(false)
  notes              String?            @db.Text
  details            RemittanceDetail[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([type, periodMonth, periodYear])
  @@index([status])
  @@index([dueDate])
  @@map("remittance_periods")
}

model RemittanceDetail {
  id                 Int              @id @default(autoincrement())
  remittancePeriodId Int
  remittancePeriod   RemittancePeriod @relation(fields: [remittancePeriodId], references: [id], onDelete: Cascade)
  employeeId         Int
  employee           Employee         @relation(fields: [employeeId], references: [id])
  employeeShare      Decimal          @default(0) @db.Decimal(15, 2)
  employerShare      Decimal          @default(0) @db.Decimal(15, 2)
  totalContribution  Decimal          @default(0) @db.Decimal(15, 2)
  grossCompensation  Decimal?         @db.Decimal(15, 2)

  @@unique([remittancePeriodId, employeeId])
  @@index([remittancePeriodId])
  @@index([employeeId])
  @@map("remittance_details")
}

// ─── Daily Remittance ──────────────────────────────────────
enum DailyRemitStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model DailyRemittance {
  id            Int                   @id @default(autoincrement())
  date          DateTime              @db.Date
  totalSales    Decimal               @default(0) @db.Decimal(15, 2)
  cashReceived  Decimal               @default(0) @db.Decimal(15, 2)
  totalExpenses Decimal               @default(0) @db.Decimal(15, 2)
  cashDisbursed Decimal               @default(0) @db.Decimal(15, 2)
  netCash       Decimal               @default(0) @db.Decimal(15, 2)
  vatCollected  Decimal               @default(0) @db.Decimal(15, 2)
  status        DailyRemitStatus      @default(DRAFT)
  preparedBy    String?               @db.VarChar(100)
  approvedBy    String?               @db.VarChar(100)
  notes         String?               @db.Text
  items         DailyRemittanceItem[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([date])
  @@index([status])
  @@index([date])
  @@map("daily_remittances")
}

model DailyRemittanceItem {
  id                Int             @id @default(autoincrement())
  dailyRemittanceId Int
  dailyRemittance   DailyRemittance @relation(fields: [dailyRemittanceId], references: [id], onDelete: Cascade)
  category          String          @db.VarChar(30)
  reference         String?         @db.VarChar(100)
  description       String          @db.VarChar(255)
  amount            Decimal         @db.Decimal(15, 2)
  meta              String?         @db.Text

  @@index([dailyRemittanceId])
  @@index([category])
  @@map("daily_remittance_items")
}

// ─── Custom Reports ────────────────────────────────────────
model CustomReport {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(150)
  description String?  @db.Text
  reportType  String   @db.VarChar(50)
  config      Json
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdBy])
  @@map("custom_reports")
}
