generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Auth ──────────────────────────────────────────────────
model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(150)
  password     String    @db.VarChar(255)
  firstName    String    @db.VarChar(80)
  lastName     String    @db.VarChar(80)
  role         Role      @default(ACCOUNTANT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([email])
  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

// ─── Chart of Accounts ─────────────────────────────────────
model Account {
  id            Int          @id @default(autoincrement())
  accountCode   String       @unique @db.VarChar(20)
  accountName   String       @db.VarChar(150)
  accountType   AccountType
  normalBalance NormalBalance
  parentId      Int?
  parent        Account?     @relation("SubAccounts", fields: [parentId], references: [id])
  children      Account[]    @relation("SubAccounts")
  isActive      Boolean      @default(true)
  description   String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  journalLines     JournalLine[]
  billLines        BillLine[]
  invoiceLines     InvoiceLine[]
  inventoryItems   InventoryItem[] @relation("InvAssetAccount")
  cogsItems        InventoryItem[] @relation("InvCogsAccount")
  revenueItems     InventoryItem[] @relation("InvRevenueAccount")

  @@index([accountCode])
  @@index([accountType])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

// ─── Journal / GL ──────────────────────────────────────────
model JournalEntry {
  id          Int             @id @default(autoincrement())
  entryNo     String          @unique @db.VarChar(30)
  entryDate   DateTime        @db.Date
  reference   String?         @db.VarChar(100)
  description String          @db.Text
  status      JournalStatus   @default(DRAFT)
  createdBy   Int
  postedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lines       JournalLine[]

  @@index([entryDate])
  @@index([status])
  @@map("journal_entries")
}

model JournalLine {
  id          Int          @id @default(autoincrement())
  entryId     Int
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0) @db.Decimal(15, 2)
  credit      Decimal      @default(0) @db.Decimal(15, 2)
  description String?      @db.VarChar(255)
  lineOrder   Int          @default(0)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

// ─── Vendors & Accounts Payable ────────────────────────────
model Vendor {
  id          Int       @id @default(autoincrement())
  vendorCode  String    @unique @db.VarChar(20)
  name        String    @db.VarChar(150)
  tin         String?   @db.VarChar(20)
  address     String?   @db.Text
  contactName String?   @db.VarChar(100)
  email       String?   @db.VarChar(150)
  phone       String?   @db.VarChar(30)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bills       Bill[]

  @@map("vendors")
}

model Bill {
  id          Int        @id @default(autoincrement())
  billNo      String     @unique @db.VarChar(30)
  vendorId    Int
  vendor      Vendor     @relation(fields: [vendorId], references: [id])
  billDate    DateTime   @db.Date
  dueDate     DateTime   @db.Date
  description String?    @db.Text
  subtotal    Decimal    @default(0) @db.Decimal(15, 2)
  vatAmount   Decimal    @default(0) @db.Decimal(15, 2)
  totalAmount Decimal    @default(0) @db.Decimal(15, 2)
  paidAmount  Decimal    @default(0) @db.Decimal(15, 2)
  status      BillStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lines       BillLine[]
  payments    PaymentAP[]

  @@index([vendorId])
  @@index([status])
  @@index([dueDate])
  @@map("bills")
}

model BillLine {
  id          Int     @id @default(autoincrement())
  billId      Int
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account @relation(fields: [accountId], references: [id])
  description String  @db.VarChar(255)
  quantity    Decimal @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal @default(0) @db.Decimal(15, 2)
  amount      Decimal @default(0) @db.Decimal(15, 2)
  vatCode     VatCode @default(VAT)

  @@index([billId])
  @@map("bill_lines")
}

model PaymentAP {
  id            Int       @id @default(autoincrement())
  paymentNo     String    @unique @db.VarChar(30)
  billId        Int
  bill          Bill      @relation(fields: [billId], references: [id])
  paymentDate   DateTime  @db.Date
  amount        Decimal   @db.Decimal(15, 2)
  paymentMethod String    @db.VarChar(50)
  reference     String?   @db.VarChar(100)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([billId])
  @@map("payments_ap")
}

enum BillStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum VatCode {
  VAT      // 12% VATable
  EXEMPT   // VAT-exempt
  ZERO     // Zero-rated
}

// ─── Customers & Accounts Receivable ───────────────────────
model Customer {
  id          Int       @id @default(autoincrement())
  customerCode String   @unique @db.VarChar(20)
  name        String    @db.VarChar(150)
  tin         String?   @db.VarChar(20)
  address     String?   @db.Text
  contactName String?   @db.VarChar(100)
  email       String?   @db.VarChar(150)
  phone       String?   @db.VarChar(30)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invoices    Invoice[]

  @@map("customers")
}

model Invoice {
  id          Int           @id @default(autoincrement())
  invoiceNo   String        @unique @db.VarChar(30)
  customerId  Int
  customer    Customer      @relation(fields: [customerId], references: [id])
  invoiceDate DateTime      @db.Date
  dueDate     DateTime      @db.Date
  description String?       @db.Text
  subtotal    Decimal       @default(0) @db.Decimal(15, 2)
  vatAmount   Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount Decimal       @default(0) @db.Decimal(15, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(15, 2)
  status      InvoiceStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lines       InvoiceLine[]
  payments    PaymentAR[]

  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id])
  description String   @db.VarChar(255)
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @default(0) @db.Decimal(15, 2)
  amount      Decimal  @default(0) @db.Decimal(15, 2)
  vatCode     VatCode  @default(VAT)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model PaymentAR {
  id            Int       @id @default(autoincrement())
  paymentNo     String    @unique @db.VarChar(30)
  invoiceId     Int
  invoice       Invoice   @relation(fields: [invoiceId], references: [id])
  paymentDate   DateTime  @db.Date
  amount        Decimal   @db.Decimal(15, 2)
  paymentMethod String    @db.VarChar(50)
  reference     String?   @db.VarChar(100)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([invoiceId])
  @@map("payments_ar")
}

enum InvoiceStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  VOID
}

// ─── Payroll ───────────────────────────────────────────────
model Employee {
  id              Int              @id @default(autoincrement())
  employeeNo      String           @unique @db.VarChar(20)
  firstName       String           @db.VarChar(80)
  lastName        String           @db.VarChar(80)
  middleName      String?          @db.VarChar(80)
  position        String?          @db.VarChar(100)
  department      String?          @db.VarChar(100)
  tin             String?          @db.VarChar(20)
  sssNo           String?          @db.VarChar(20)
  philhealthNo    String?          @db.VarChar(20)
  pagibigNo       String?          @db.VarChar(20)
  hireDate        DateTime         @db.Date
  employmentType  EmploymentType   @default(REGULAR)
  payFrequency    PayFrequency     @default(SEMI_MONTHLY)
  basicSalary     Decimal          @db.Decimal(15, 2)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  payrollItems      PayrollItem[]
  remittanceDetails RemittanceDetail[]

  @@map("employees")
}

model PayrollPeriod {
  id          Int           @id @default(autoincrement())
  periodName  String        @db.VarChar(80)
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  payDate     DateTime      @db.Date
  status      PeriodStatus  @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       PayrollItem[]

  @@index([status])
  @@map("payroll_periods")
}

model PayrollItem {
  id              Int           @id @default(autoincrement())
  periodId        Int
  period          PayrollPeriod @relation(fields: [periodId], references: [id])
  employeeId      Int
  employee        Employee      @relation(fields: [employeeId], references: [id])
  basicPay        Decimal       @db.Decimal(15, 2)
  allowances      Decimal       @default(0) @db.Decimal(15, 2)
  overtimePay     Decimal       @default(0) @db.Decimal(15, 2)
  grossPay        Decimal       @db.Decimal(15, 2)
  sssEmployee     Decimal       @default(0) @db.Decimal(15, 2)
  sssEmployer     Decimal       @default(0) @db.Decimal(15, 2)
  philhealthEe    Decimal       @default(0) @db.Decimal(15, 2)
  philhealthEr    Decimal       @default(0) @db.Decimal(15, 2)
  pagibigEe       Decimal       @default(0) @db.Decimal(15, 2)
  pagibigEr       Decimal       @default(0) @db.Decimal(15, 2)
  withholdingTax  Decimal       @default(0) @db.Decimal(15, 2)
  totalDeductions Decimal       @db.Decimal(15, 2)
  netPay          Decimal       @db.Decimal(15, 2)
  createdAt       DateTime      @default(now())

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
  @@map("payroll_items")
}

enum EmploymentType {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  PART_TIME
}

enum PayFrequency {
  WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum PeriodStatus {
  OPEN
  COMPUTED
  APPROVED
  PAID
}

// ─── System Settings ───────────────────────────────────────
model SystemSetting {
  id        Int      @id @default(autoincrement())
  key       String   @unique @db.VarChar(100)
  value     String   @db.Text
  updatedAt DateTime @updatedAt

  @@map("system_settings")
}

// ─── Inventory ─────────────────────────────────────────────
model InventoryCategory {
  id          Int               @id @default(autoincrement())
  name        String            @db.VarChar(100)
  type        InvCategoryType   @default(PRODUCT)
  description String?           @db.Text
  isActive    Boolean           @default(true)
  items       InventoryItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@map("inventory_categories")
}

enum InvCategoryType {
  PRODUCT   // retail goods for sale
  MATERIAL  // advertising / production materials
  SUPPLY    // consumable office or production supplies
  ASSET     // promotional assets / display units
}

model InventoryItem {
  id                  Int                    @id @default(autoincrement())
  sku                 String                 @unique @db.VarChar(50)
  name                String                 @db.VarChar(150)
  description         String?                @db.Text
  categoryId          Int?
  category            InventoryCategory?     @relation(fields: [categoryId], references: [id])
  unit                String                 @default("pcs") @db.VarChar(20)
  costPrice           Decimal                @default(0) @db.Decimal(15, 2)
  sellingPrice        Decimal                @default(0) @db.Decimal(15, 2)
  currentStock        Decimal                @default(0) @db.Decimal(12, 3)
  reorderLevel        Decimal                @default(0) @db.Decimal(12, 3)
  warehouseLocation   String?                @db.VarChar(100)
  inventoryAccountId  Int?
  inventoryAccount    Account?               @relation("InvAssetAccount",   fields: [inventoryAccountId], references: [id])
  cogsAccountId       Int?
  cogsAccount         Account?               @relation("InvCogsAccount",    fields: [cogsAccountId],      references: [id])
  revenueAccountId    Int?
  revenueAccount      Account?               @relation("InvRevenueAccount", fields: [revenueAccountId],   references: [id])
  isActive            Boolean                @default(true)
  transactions        InventoryTransaction[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([sku])
  @@index([categoryId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id           Int           @id @default(autoincrement())
  txnNo        String        @unique @db.VarChar(30)
  itemId       Int
  item         InventoryItem @relation(fields: [itemId], references: [id])
  type         InvTxnType
  quantity     Decimal       @db.Decimal(12, 3)
  unitCost     Decimal       @default(0) @db.Decimal(15, 2)
  totalCost    Decimal       @default(0) @db.Decimal(15, 2)
  runningStock Decimal       @default(0) @db.Decimal(12, 3)
  reference    String?       @db.VarChar(100)
  notes        String?       @db.Text
  txnDate      DateTime      @db.Date
  createdBy    String?       @db.VarChar(100)
  createdAt    DateTime      @default(now())

  @@index([itemId])
  @@index([txnDate])
  @@index([type])
  @@map("inventory_transactions")
}

enum InvTxnType {
  IN         // stock received / purchase
  OUT        // stock issued / sold
  ADJUSTMENT // manual stock count adjustment
  RETURN_IN  // customer return — stock comes back
  RETURN_OUT // return to supplier — stock leaves
}

