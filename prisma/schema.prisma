generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Multi-Business ────────────────────────────────────────
model Business {
  id          Int       @id @default(autoincrement())
  code        String    @unique @db.VarChar(20)
  name        String    @db.VarChar(150)
  tin         String?   @db.VarChar(30)
  address     String?   @db.Text
  phone       String?   @db.VarChar(30)
  email       String?   @db.VarChar(150)
  industry    String?   @db.VarChar(80)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  userBusinesses UserBusiness[]

  @@map("businesses")
}

model UserBusiness {
  id         Int      @id @default(autoincrement())
  userId     Int
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessId Int
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([userId, businessId])
  @@index([userId])
  @@index([businessId])
  @@map("user_businesses")
}

// ─── Auth ──────────────────────────────────────────────────
model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(150)
  password     String    @db.VarChar(255)
  firstName    String    @db.VarChar(80)
  lastName     String    @db.VarChar(80)
  role         Role      @default(ACCOUNTANT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?

  // ── Auth hardening (account lockout) ──
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?

  // ── Password reset ──
  resetToken          String?   @db.VarChar(255)
  resetTokenExpiry    DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  auditLogs      AuditLog[]
  userBusinesses UserBusiness[]

  @@index([email])
  @@map("users")
}

enum Role {
  ADMIN
  MANAGER
  ACCOUNTANT
  VIEWER
}

// ─── Audit Trail ───────────────────────────────────────────
model AuditLog {
  id         Int       @id @default(autoincrement())
  userId     Int?
  user       User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  userEmail  String?   @db.VarChar(150)
  businessId Int?      // which business context this audit happened in
  action     String    @db.VarChar(40)
  entity     String    @db.VarChar(60)
  entityId   String?   @db.VarChar(40)
  summary    String?   @db.VarChar(255)
  changes    Json?
  ipAddress  String?   @db.VarChar(60)
  userAgent  String?   @db.VarChar(255)
  createdAt  DateTime  @default(now())

  @@index([entity, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([businessId])
  @@map("audit_logs")
}

// ─── Chart of Accounts ─────────────────────────────────────
model Account {
  id            Int          @id @default(autoincrement())
  businessId    Int          @default(1)
  accountCode   String       @db.VarChar(20)
  accountName   String       @db.VarChar(150)
  accountType   AccountType
  normalBalance NormalBalance
  parentId      Int?
  parent        Account?     @relation("SubAccounts", fields: [parentId], references: [id])
  children      Account[]    @relation("SubAccounts")
  isActive      Boolean      @default(true)
  description   String?      @db.Text
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  journalLines     JournalLine[]
  billLines        BillLine[]
  invoiceLines     InvoiceLine[]
  inventoryItems   InventoryItem[]     @relation("InvAssetAccount")
  cogsItems        InventoryItem[]     @relation("InvCogsAccount")
  revenueItems     InventoryItem[]     @relation("InvRevenueAccount")
  expenseItems     ExpenseVoucherItem[]

  @@unique([businessId, accountCode])
  @@index([businessId])
  @@index([accountType])
  @@map("accounts")
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum NormalBalance {
  DEBIT
  CREDIT
}

// ─── Journal / GL ──────────────────────────────────────────
model JournalEntry {
  id          Int             @id @default(autoincrement())
  businessId  Int             @default(1)
  entryNo     String          @unique @db.VarChar(30)
  entryDate   DateTime        @db.Date
  reference   String?         @db.VarChar(100)
  description String          @db.Text
  status      JournalStatus   @default(DRAFT)
  createdBy   Int
  postedAt    DateTime?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  lines       JournalLine[]

  @@index([businessId])
  @@index([entryDate])
  @@index([status])
  @@map("journal_entries")
}

model JournalLine {
  id          Int          @id @default(autoincrement())
  entryId     Int
  entry       JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account      @relation(fields: [accountId], references: [id])
  debit       Decimal      @default(0) @db.Decimal(15, 2)
  credit      Decimal      @default(0) @db.Decimal(15, 2)
  description String?      @db.VarChar(255)
  lineOrder   Int          @default(0)

  @@index([entryId])
  @@index([accountId])
  @@map("journal_lines")
}

enum JournalStatus {
  DRAFT
  POSTED
  VOIDED
}

// ─── Vendors & Accounts Payable ────────────────────────────
model Vendor {
  id          Int       @id @default(autoincrement())
  businessId  Int       @default(1)
  vendorCode  String    @db.VarChar(20)
  name        String    @db.VarChar(150)
  tin         String?   @db.VarChar(20)
  address     String?   @db.Text
  contactName String?   @db.VarChar(100)
  email       String?   @db.VarChar(150)
  phone       String?   @db.VarChar(30)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  bills          Bill[]
  purchaseOrders PurchaseOrder[]

  @@unique([businessId, vendorCode])
  @@index([businessId])
  @@map("vendors")
}

model Bill {
  id          Int        @id @default(autoincrement())
  businessId  Int        @default(1)
  billNo      String     @unique @db.VarChar(30)
  vendorId    Int
  vendor      Vendor     @relation(fields: [vendorId], references: [id])
  billDate    DateTime   @db.Date
  dueDate     DateTime   @db.Date
  description String?    @db.Text
  subtotal    Decimal    @default(0) @db.Decimal(15, 2)
  vatAmount   Decimal    @default(0) @db.Decimal(15, 2)
  totalAmount Decimal    @default(0) @db.Decimal(15, 2)
  paidAmount  Decimal    @default(0) @db.Decimal(15, 2)
  status      BillStatus @default(OPEN)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  lines       BillLine[]
  payments    PaymentAP[]

  @@index([businessId])
  @@index([vendorId])
  @@index([status])
  @@index([dueDate])
  @@map("bills")
}

model BillLine {
  id          Int     @id @default(autoincrement())
  billId      Int
  bill        Bill    @relation(fields: [billId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account @relation(fields: [accountId], references: [id])
  description String  @db.VarChar(255)
  quantity    Decimal @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal @default(0) @db.Decimal(15, 2)
  amount      Decimal @default(0) @db.Decimal(15, 2)
  vatCode     VatCode @default(VAT)

  @@index([billId])
  @@map("bill_lines")
}

model PaymentAP {
  id            Int       @id @default(autoincrement())
  paymentNo     String    @unique @db.VarChar(30)
  billId        Int
  bill          Bill      @relation(fields: [billId], references: [id])
  paymentDate   DateTime  @db.Date
  amount        Decimal   @db.Decimal(15, 2)
  paymentMethod String    @db.VarChar(50)
  reference     String?   @db.VarChar(100)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([billId])
  @@map("payments_ap")
}

enum BillStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  VOID
}

enum VatCode {
  VAT      // 12% VATable
  EXEMPT   // VAT-exempt
  ZERO     // Zero-rated
}

// ─── Customers & Accounts Receivable ───────────────────────
model Customer {
  id           Int       @id @default(autoincrement())
  businessId   Int       @default(1)
  customerCode String    @db.VarChar(20)
  name         String    @db.VarChar(150)
  tin          String?   @db.VarChar(20)
  address      String?   @db.Text
  contactName  String?   @db.VarChar(100)
  email        String?   @db.VarChar(150)
  phone        String?   @db.VarChar(30)
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  invoices    Invoice[]

  @@unique([businessId, customerCode])
  @@index([businessId])
  @@map("customers")
}

model Invoice {
  id          Int           @id @default(autoincrement())
  businessId  Int           @default(1)
  invoiceNo   String        @unique @db.VarChar(30)
  customerId  Int
  customer    Customer      @relation(fields: [customerId], references: [id])
  invoiceDate DateTime      @db.Date
  dueDate     DateTime      @db.Date
  description String?       @db.Text
  subtotal    Decimal       @default(0) @db.Decimal(15, 2)
  vatAmount   Decimal       @default(0) @db.Decimal(15, 2)
  totalAmount Decimal       @default(0) @db.Decimal(15, 2)
  paidAmount  Decimal       @default(0) @db.Decimal(15, 2)
  status      InvoiceStatus @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  lines       InvoiceLine[]
  payments    PaymentAR[]

  @@index([businessId])
  @@index([customerId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model InvoiceLine {
  id          Int      @id @default(autoincrement())
  invoiceId   Int
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  accountId   Int
  account     Account  @relation(fields: [accountId], references: [id])
  description String   @db.VarChar(255)
  quantity    Decimal  @default(1) @db.Decimal(10, 3)
  unitPrice   Decimal  @default(0) @db.Decimal(15, 2)
  amount      Decimal  @default(0) @db.Decimal(15, 2)
  vatCode     VatCode  @default(VAT)

  @@index([invoiceId])
  @@map("invoice_lines")
}

model PaymentAR {
  id            Int       @id @default(autoincrement())
  paymentNo     String    @unique @db.VarChar(30)
  invoiceId     Int
  invoice       Invoice   @relation(fields: [invoiceId], references: [id])
  paymentDate   DateTime  @db.Date
  amount        Decimal   @db.Decimal(15, 2)
  paymentMethod String    @db.VarChar(50)
  reference     String?   @db.VarChar(100)
  notes         String?   @db.Text
  createdAt     DateTime  @default(now())

  @@index([invoiceId])
  @@map("payments_ar")
}

enum InvoiceStatus {
  OPEN
  PARTIAL
  PAID
  OVERDUE
  VOID
}

// ─── Payroll ───────────────────────────────────────────────
model Employee {
  id              Int              @id @default(autoincrement())
  businessId      Int              @default(1)
  employeeNo      String           @db.VarChar(20)
  firstName       String           @db.VarChar(80)
  lastName        String           @db.VarChar(80)
  middleName      String?          @db.VarChar(80)
  position        String?          @db.VarChar(100)
  department      String?          @db.VarChar(100)
  tin             String?          @db.VarChar(20)
  sssNo           String?          @db.VarChar(20)
  philhealthNo    String?          @db.VarChar(20)
  pagibigNo       String?          @db.VarChar(20)
  hireDate        DateTime         @db.Date
  employmentType  EmploymentType   @default(REGULAR)
  payFrequency    PayFrequency     @default(SEMI_MONTHLY)
  basicSalary     Decimal          @db.Decimal(15, 2)
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  payrollItems      PayrollItem[]
  remittanceDetails RemittanceDetail[]

  @@unique([businessId, employeeNo])
  @@index([businessId])
  @@map("employees")
}

model PayrollPeriod {
  id          Int           @id @default(autoincrement())
  businessId  Int           @default(1)
  periodName  String        @db.VarChar(80)
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  payDate     DateTime      @db.Date
  status      PeriodStatus  @default(OPEN)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  items       PayrollItem[]

  @@index([businessId])
  @@index([status])
  @@map("payroll_periods")
}

model PayrollItem {
  id              Int           @id @default(autoincrement())
  periodId        Int
  period          PayrollPeriod @relation(fields: [periodId], references: [id])
  employeeId      Int
  employee        Employee      @relation(fields: [employeeId], references: [id])
  basicPay        Decimal       @db.Decimal(15, 2)
  allowances      Decimal       @default(0) @db.Decimal(15, 2)
  overtimePay     Decimal       @default(0) @db.Decimal(15, 2)
  grossPay        Decimal       @db.Decimal(15, 2)
  sssEmployee     Decimal       @default(0) @db.Decimal(15, 2)
  sssEmployer     Decimal       @default(0) @db.Decimal(15, 2)
  philhealthEe    Decimal       @default(0) @db.Decimal(15, 2)
  philhealthEr    Decimal       @default(0) @db.Decimal(15, 2)
  pagibigEe       Decimal       @default(0) @db.Decimal(15, 2)
  pagibigEr       Decimal       @default(0) @db.Decimal(15, 2)
  withholdingTax  Decimal       @default(0) @db.Decimal(15, 2)
  totalDeductions Decimal       @db.Decimal(15, 2)
  netPay          Decimal       @db.Decimal(15, 2)
  createdAt       DateTime      @default(now())

  @@unique([periodId, employeeId])
  @@index([periodId])
  @@index([employeeId])
  @@map("payroll_items")
}

enum EmploymentType {
  REGULAR
  PROBATIONARY
  CONTRACTUAL
  PART_TIME
}

enum PayFrequency {
  WEEKLY
  SEMI_MONTHLY
  MONTHLY
}

enum PeriodStatus {
  OPEN
  COMPUTED
  APPROVED
  PAID
}

// ─── System Settings ───────────────────────────────────────
model SystemSetting {
  id         Int      @id @default(autoincrement())
  businessId Int      @default(1)
  key        String   @db.VarChar(100)
  value      String   @db.Text
  updatedAt  DateTime @updatedAt

  @@unique([businessId, key])
  @@index([businessId])
  @@map("system_settings")
}

// ─── Inventory ─────────────────────────────────────────────
model InventoryCategory {
  id          Int               @id @default(autoincrement())
  businessId  Int               @default(1)
  name        String            @db.VarChar(100)
  type        InvCategoryType   @default(PRODUCT)
  description String?           @db.Text
  isActive    Boolean           @default(true)
  items       InventoryItem[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([businessId])
  @@map("inventory_categories")
}

enum InvCategoryType {
  PRODUCT   // retail goods for sale
  MATERIAL  // advertising / production materials
  SUPPLY    // consumable office or production supplies
  ASSET     // promotional assets / display units
}

model InventoryItem {
  id                  Int                    @id @default(autoincrement())
  businessId          Int                    @default(1)
  sku                 String                 @db.VarChar(50)
  name                String                 @db.VarChar(150)
  description         String?                @db.Text
  categoryId          Int?
  category            InventoryCategory?     @relation(fields: [categoryId], references: [id])
  unit                String                 @default("pcs") @db.VarChar(20)
  costPrice           Decimal                @default(0) @db.Decimal(15, 2)
  sellingPrice        Decimal                @default(0) @db.Decimal(15, 2)
  currentStock        Decimal                @default(0) @db.Decimal(12, 3)
  reorderLevel        Decimal                @default(0) @db.Decimal(12, 3)
  warehouseLocation   String?                @db.VarChar(100)
  inventoryAccountId  Int?
  inventoryAccount    Account?               @relation("InvAssetAccount",   fields: [inventoryAccountId], references: [id])
  cogsAccountId       Int?
  cogsAccount         Account?               @relation("InvCogsAccount",    fields: [cogsAccountId],      references: [id])
  revenueAccountId    Int?
  revenueAccount      Account?               @relation("InvRevenueAccount", fields: [revenueAccountId],   references: [id])
  isActive            Boolean                @default(true)
  transactions        InventoryTransaction[]
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@unique([businessId, sku])
  @@index([businessId])
  @@index([categoryId])
  @@map("inventory_items")
}

model InventoryTransaction {
  id           Int           @id @default(autoincrement())
  txnNo        String        @unique @db.VarChar(30)
  itemId       Int
  item         InventoryItem @relation(fields: [itemId], references: [id])
  type         InvTxnType
  quantity     Decimal       @db.Decimal(12, 3)
  unitCost     Decimal       @default(0) @db.Decimal(15, 2)
  totalCost    Decimal       @default(0) @db.Decimal(15, 2)
  runningStock Decimal       @default(0) @db.Decimal(12, 3)
  reference    String?       @db.VarChar(100)
  notes        String?       @db.Text
  txnDate      DateTime      @db.Date
  createdBy    String?       @db.VarChar(100)
  createdAt    DateTime      @default(now())

  @@index([itemId])
  @@index([txnDate])
  @@index([type])
  @@map("inventory_transactions")
}

enum InvTxnType {
  IN
  OUT
  ADJUSTMENT
  RETURN_IN
  RETURN_OUT
}

// ─── Remittances ───────────────────────────────────────────
enum RemittanceType {
  SSS
  PHILHEALTH
  PAGIBIG
  BIR_1601C
}

enum RemittanceStatus {
  DRAFT
  FILED
  PAID
  OVERDUE
}

model RemittancePeriod {
  id                 Int                @id @default(autoincrement())
  businessId         Int                @default(1)
  type               RemittanceType
  periodMonth        Int
  periodYear         Int
  dueDate            DateTime           @db.Date
  totalEmployeeShare Decimal            @default(0) @db.Decimal(15, 2)
  totalEmployerShare Decimal            @default(0) @db.Decimal(15, 2)
  totalAmount        Decimal            @default(0) @db.Decimal(15, 2)
  status             RemittanceStatus   @default(DRAFT)
  referenceNo        String?            @db.VarChar(100)
  filedDate          DateTime?          @db.Date
  paidDate           DateTime?          @db.Date
  paidAmount         Decimal?           @db.Decimal(15, 2)
  penalty            Decimal            @default(0) @db.Decimal(15, 2)
  isManual           Boolean            @default(false)
  notes              String?            @db.Text
  details            RemittanceDetail[]
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  @@unique([businessId, type, periodMonth, periodYear])
  @@index([businessId])
  @@index([status])
  @@index([dueDate])
  @@map("remittance_periods")
}

model RemittanceDetail {
  id                 Int              @id @default(autoincrement())
  remittancePeriodId Int
  remittancePeriod   RemittancePeriod @relation(fields: [remittancePeriodId], references: [id], onDelete: Cascade)
  employeeId         Int
  employee           Employee         @relation(fields: [employeeId], references: [id])
  employeeShare      Decimal          @default(0) @db.Decimal(15, 2)
  employerShare      Decimal          @default(0) @db.Decimal(15, 2)
  totalContribution  Decimal          @default(0) @db.Decimal(15, 2)
  grossCompensation  Decimal?         @db.Decimal(15, 2)

  @@unique([remittancePeriodId, employeeId])
  @@index([remittancePeriodId])
  @@index([employeeId])
  @@map("remittance_details")
}

// ─── Expense Vouchers ──────────────────────────────────────
enum ExpenseType {
  PETTY_CASH
  REIMBURSEMENT
  DIRECT_PAYMENT
  CASH_ADVANCE
  LIQUIDATION
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PAID
  REJECTED
}

model ExpenseVoucher {
  id             Int                  @id @default(autoincrement())
  businessId     Int                  @default(1)
  voucherNo      String               @unique @db.VarChar(30)
  type           ExpenseType          @default(PETTY_CASH)
  date           DateTime             @db.Date
  payee          String               @db.VarChar(150)
  category       String               @db.VarChar(60)
  purpose        String               @db.Text
  totalAmount    Decimal              @default(0) @db.Decimal(15, 2)
  receiptNo      String?              @db.VarChar(100)
  status         ExpenseStatus        @default(DRAFT)
  requestedBy    String?              @db.VarChar(100)
  approvedBy     String?              @db.VarChar(100)
  paidDate       DateTime?            @db.Date
  paidBy         String?              @db.VarChar(100)
  rejectedReason String?              @db.Text
  notes          String?              @db.Text
  items          ExpenseVoucherItem[]
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@index([businessId])
  @@index([date])
  @@index([status])
  @@index([type])
  @@map("expense_vouchers")
}

model ExpenseVoucherItem {
  id          Int             @id @default(autoincrement())
  voucherId   Int
  voucher     ExpenseVoucher  @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  description String          @db.VarChar(255)
  accountId   Int?
  account     Account?        @relation(fields: [accountId], references: [id])
  amount      Decimal         @db.Decimal(15, 2)
  receiptNo   String?         @db.VarChar(100)

  @@index([voucherId])
  @@map("expense_voucher_items")
}

// ─── Daily Remittance ──────────────────────────────────────
enum DailyRemitStatus {
  DRAFT
  SUBMITTED
  APPROVED
}

model DailyRemittance {
  id            Int                   @id @default(autoincrement())
  businessId    Int                   @default(1)
  date          DateTime              @db.Date
  totalSales    Decimal               @default(0) @db.Decimal(15, 2)
  cashReceived  Decimal               @default(0) @db.Decimal(15, 2)
  totalExpenses Decimal               @default(0) @db.Decimal(15, 2)
  cashDisbursed Decimal               @default(0) @db.Decimal(15, 2)
  netCash       Decimal               @default(0) @db.Decimal(15, 2)
  vatCollected  Decimal               @default(0) @db.Decimal(15, 2)
  status        DailyRemitStatus      @default(DRAFT)
  preparedBy    String?               @db.VarChar(100)
  approvedBy    String?               @db.VarChar(100)
  notes         String?               @db.Text
  items         DailyRemittanceItem[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([businessId, date])
  @@index([businessId])
  @@index([status])
  @@index([date])
  @@map("daily_remittances")
}

model DailyRemittanceItem {
  id                Int             @id @default(autoincrement())
  dailyRemittanceId Int
  dailyRemittance   DailyRemittance @relation(fields: [dailyRemittanceId], references: [id], onDelete: Cascade)
  category          String          @db.VarChar(30)
  reference         String?         @db.VarChar(100)
  description       String          @db.VarChar(255)
  amount            Decimal         @db.Decimal(15, 2)
  meta              String?         @db.Text

  @@index([dailyRemittanceId])
  @@index([category])
  @@map("daily_remittance_items")
}

// ─── Custom Reports ────────────────────────────────────────
model CustomReport {
  id          Int      @id @default(autoincrement())
  businessId  Int      @default(1)
  name        String   @db.VarChar(150)
  description String?  @db.Text
  reportType  String   @db.VarChar(50)
  config      Json
  createdBy   Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([businessId])
  @@index([createdBy])
  @@map("custom_reports")
}

// ─── File Attachments ──────────────────────────────────────
model Attachment {
  id           Int      @id @default(autoincrement())
  entity       String   @db.VarChar(60)
  entityId     Int
  fileName     String   @db.VarChar(255)
  originalName String   @db.VarChar(255)
  mimeType     String   @db.VarChar(120)
  size         Int
  uploadedBy   Int?
  createdAt    DateTime @default(now())

  @@index([entity, entityId])
  @@map("attachments")
}

// ─── Purchase Orders ───────────────────────────────────────
enum POStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  BILLED
  CANCELLED
}

model PurchaseOrder {
  id           Int       @id @default(autoincrement())
  businessId   Int       @default(1)
  poNumber     String    @unique @db.VarChar(30)
  vendorId     Int
  vendor       Vendor    @relation(fields: [vendorId], references: [id])
  orderDate    DateTime  @db.Date
  expectedDate DateTime? @db.Date
  status       POStatus  @default(DRAFT)
  notes        String?   @db.Text
  subtotal     Decimal   @default(0) @db.Decimal(15, 2)
  taxAmount    Decimal   @default(0) @db.Decimal(15, 2)
  total        Decimal   @default(0) @db.Decimal(15, 2)
  billId       Int?
  createdBy    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  lines        PurchaseOrderLine[]

  @@index([businessId])
  @@index([vendorId])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id          Int           @id @default(autoincrement())
  poId        Int
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  description String        @db.VarChar(255)
  quantity    Decimal       @db.Decimal(15, 2)
  unitPrice   Decimal       @db.Decimal(15, 2)
  receivedQty Decimal       @default(0) @db.Decimal(15, 2)
  amount      Decimal       @db.Decimal(15, 2)
  accountId   Int?
  lineOrder   Int           @default(0)

  @@index([poId])
  @@map("purchase_order_lines")
}

// ─── Fixed Assets & Depreciation ───────────────────────────
enum DepreciationMethod {
  STRAIGHT_LINE
  DECLINING_BALANCE
}

enum AssetStatus {
  ACTIVE
  FULLY_DEPRECIATED
  DISPOSED
}

model FixedAsset {
  id                               Int                @id @default(autoincrement())
  businessId                       Int                @default(1)
  assetCode                        String             @unique @db.VarChar(30)
  name                             String             @db.VarChar(150)
  category                         String?            @db.VarChar(80)
  acquisitionDate                  DateTime           @db.Date
  cost                             Decimal            @db.Decimal(15, 2)
  salvageValue                     Decimal            @default(0) @db.Decimal(15, 2)
  usefulLifeMonths                 Int
  method                           DepreciationMethod @default(STRAIGHT_LINE)
  decliningRate                    Decimal?           @db.Decimal(7, 4)
  accumulatedDepreciation          Decimal            @default(0) @db.Decimal(15, 2)
  bookValue                        Decimal            @db.Decimal(15, 2)
  status                           AssetStatus        @default(ACTIVE)
  assetAccountId                   Int?
  depreciationExpenseAccountId     Int?
  accumulatedDepreciationAccountId Int?
  disposalDate                     DateTime?          @db.Date
  disposalAmount                   Decimal?           @db.Decimal(15, 2)
  notes                            String?            @db.Text
  createdAt                        DateTime           @default(now())
  updatedAt                        DateTime           @updatedAt

  depreciationEntries DepreciationEntry[]

  @@index([businessId])
  @@index([status])
  @@map("fixed_assets")
}

model DepreciationEntry {
  id             Int        @id @default(autoincrement())
  assetId        Int
  asset          FixedAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  periodDate     DateTime   @db.Date
  amount         Decimal    @db.Decimal(15, 2)
  bookValueAfter Decimal    @db.Decimal(15, 2)
  journalEntryId Int?
  createdAt      DateTime   @default(now())

  @@unique([assetId, periodDate])
  @@map("depreciation_entries")
}

// ─── Bank Reconciliation ───────────────────────────────────
model BankAccount {
  id             Int       @id @default(autoincrement())
  businessId     Int       @default(1)
  name           String    @db.VarChar(120)
  bankName       String?   @db.VarChar(120)
  accountNumber  String?   @db.VarChar(60)
  glAccountId    Int?
  currentBalance Decimal   @default(0) @db.Decimal(15, 2)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  reconciliations BankReconciliation[]
  transactions    BankTransaction[]

  @@index([businessId])
  @@map("bank_accounts")
}

model BankReconciliation {
  id                Int         @id @default(autoincrement())
  bankAccountId     Int
  bankAccount       BankAccount @relation(fields: [bankAccountId], references: [id])
  statementDate     DateTime    @db.Date
  statementBalance  Decimal     @db.Decimal(15, 2)
  reconciledBalance Decimal     @default(0) @db.Decimal(15, 2)
  status            String      @default("OPEN") @db.VarChar(20)
  notes             String?     @db.Text
  createdBy         Int?
  createdAt         DateTime    @default(now())
  completedAt       DateTime?

  transactions BankTransaction[]

  @@index([bankAccountId])
  @@map("bank_reconciliations")
}

model BankTransaction {
  id               Int                 @id @default(autoincrement())
  bankAccountId    Int
  bankAccount      BankAccount         @relation(fields: [bankAccountId], references: [id])
  reconciliationId Int?
  reconciliation   BankReconciliation? @relation(fields: [reconciliationId], references: [id], onDelete: SetNull)
  txnDate          DateTime            @db.Date
  description      String              @db.VarChar(255)
  reference        String?             @db.VarChar(80)
  amount           Decimal             @db.Decimal(15, 2)
  type             String              @db.VarChar(12)
  isReconciled     Boolean             @default(false)
  journalEntryId   Int?
  createdAt        DateTime            @default(now())

  @@index([bankAccountId])
  @@index([reconciliationId])
  @@map("bank_transactions")
}

// ─── Budgeting ─────────────────────────────────────────────
model Budget {
  id         Int      @id @default(autoincrement())
  businessId Int      @default(1)
  name       String   @db.VarChar(120)
  fiscalYear Int
  status     String   @default("ACTIVE") @db.VarChar(20)
  notes      String?  @db.Text
  createdBy  Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  lines BudgetLine[]

  @@unique([businessId, name, fiscalYear])
  @@index([businessId])
  @@map("budgets")
}

model BudgetLine {
  id           Int     @id @default(autoincrement())
  budgetId     Int
  budget       Budget  @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  accountId    Int
  annualAmount Decimal @default(0) @db.Decimal(15, 2)

  @@unique([budgetId, accountId])
  @@map("budget_lines")
}

// ─── Recurring Templates ───────────────────────────────────
enum RecurringFrequency {
  WEEKLY
  MONTHLY
  QUARTERLY
  ANNUALLY
}

model RecurringTemplate {
  id          Int                @id @default(autoincrement())
  businessId  Int                @default(1)
  name        String             @db.VarChar(120)
  type        String             @default("JOURNAL") @db.VarChar(20)
  frequency   RecurringFrequency @default(MONTHLY)
  startDate   DateTime           @db.Date
  endDate     DateTime?          @db.Date
  nextRunDate DateTime           @db.Date
  lastRunDate DateTime?
  isActive    Boolean            @default(true)
  description String?            @db.VarChar(255)
  reference   String?            @db.VarChar(80)
  payload     Json
  createdBy   Int?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([businessId])
  @@index([isActive, nextRunDate])
  @@map("recurring_templates")
}
